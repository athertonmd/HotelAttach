{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hci.platform/schemas/opportunity-updated.schema.json",
  "title": "OpportunityUpdated Event",
  "description": "Published when an opportunity's score, priority, or lifecycle state changes due to reassessment",
  "allOf": [
    {
      "$ref": "envelope.schema.json"
    }
  ],
  "properties": {
    "eventType": {
      "const": "OpportunityUpdated"
    },
    "payload": {
      "$ref": "#/definitions/OpportunityUpdatedPayload"
    }
  },
  "definitions": {
    "OpportunityUpdatedPayload": {
      "type": "object",
      "required": [
        "opportunityId",
        "tenantId",
        "corporateId",
        "tripId",
        "opportunityType",
        "lifecycleState",
        "previousScore",
        "newScore",
        "previousPriority",
        "newPriority",
        "updatedAt"
      ],
      "properties": {
        "opportunityId": {
          "type": "string",
          "format": "uuid"
        },
        "tenantId": {
          "type": "string",
          "format": "uuid"
        },
        "corporateId": {
          "type": "string",
          "format": "uuid"
        },
        "tripId": {
          "type": "string",
          "format": "uuid"
        },
        "opportunityType": {
          "type": "string",
          "enum": [
            "missing_hotel",
            "partial_coverage",
            "out_of_policy",
            "direct_booked",
            "preferred_supplier",
            "duty_of_care_gap",
            "orphan_hotel_review"
          ]
        },
        "lifecycleState": {
          "type": "string",
          "enum": [
            "detected",
            "qualified",
            "suppressed",
            "awaiting_action",
            "active",
            "communicated",
            "converted",
            "fulfilled",
            "closed",
            "rejected",
            "expired",
            "cancelled"
          ]
        },
        "previousScore": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "newScore": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "previousPriority": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low"]
        },
        "newPriority": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low"]
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "previousState": {
          "type": ["string", "null"],
          "enum": [
            "detected",
            "qualified",
            "suppressed",
            "awaiting_action",
            "active",
            "communicated",
            "converted",
            "fulfilled",
            "closed",
            "rejected",
            "expired",
            "cancelled",
            null
          ]
        },
        "scoreChangeReason": {
          "type": ["string", "null"],
          "maxLength": 1000
        },
        "ruleIdsApplied": {
          "type": ["array", "null"],
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "estimatedSpend": {
          "type": ["number", "null"],
          "minimum": 0
        },
        "reopenCount": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "triggeringEventId": {
          "type": ["string", "null"],
          "format": "uuid"
        },
        "triggeringEventType": {
          "type": ["string", "null"]
        },
        "recommendation": {
          "oneOf": [{ "$ref": "#/definitions/Recommendation" }, { "type": "null" }]
        }
      },
      "additionalProperties": false
    },
    "Recommendation": {
      "type": "object",
      "required": ["recommendationType", "recommendationText", "priority"],
      "properties": {
        "recommendationType": {
          "type": "string",
          "enum": [
            "book_hotel",
            "add_nights",
            "move_to_preferred",
            "review_policy_exception",
            "contact_tmc",
            "confirm_accommodation",
            "cancel_external_booking"
          ]
        },
        "recommendationText": {
          "type": "string",
          "maxLength": 1000
        },
        "priority": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low"]
        },
        "preferredSupplierId": {
          "type": ["string", "null"],
          "format": "uuid"
        },
        "estimatedNights": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "estimatedCost": {
          "type": ["number", "null"],
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  }
}
