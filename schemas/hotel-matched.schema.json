{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hci.platform/schemas/hotel-matched.schema.json",
  "title": "HotelMatched Event",
  "description": "Published when a hotel booking is matched to a trip by the Booking Reconciliation Engine",
  "allOf": [
    {
      "$ref": "envelope.schema.json"
    }
  ],
  "properties": {
    "eventType": {
      "const": "HotelMatched"
    },
    "payload": {
      "$ref": "#/definitions/HotelMatchedPayload"
    }
  },
  "definitions": {
    "HotelMatchedPayload": {
      "type": "object",
      "required": [
        "matchId",
        "tripId",
        "bookingId",
        "travellerId",
        "tenantId",
        "confidence",
        "reasonCodes"
      ],
      "properties": {
        "matchId": {
          "type": "string",
          "format": "uuid"
        },
        "tripId": {
          "type": "string",
          "format": "uuid"
        },
        "bookingId": {
          "type": "string",
          "format": "uuid"
        },
        "travellerId": {
          "type": "string",
          "format": "uuid"
        },
        "tenantId": {
          "type": "string",
          "format": "uuid"
        },
        "confidence": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "reasonCodes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "coveragePercent": {
          "type": ["integer", "null"],
          "minimum": 0,
          "maximum": 100
        },
        "matchedAt": {
          "type": ["string", "null"],
          "format": "date-time"
        }
      },
      "additionalProperties": false
    }
  }
}
