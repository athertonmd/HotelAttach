{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hci.platform/schemas/opportunity-closed.schema.json",
  "title": "OpportunityClosed Event",
  "description": "Published when an opportunity reaches a terminal closed state. Consolidates expired, cancelled, and fulfilled scenarios via closureReason.",
  "allOf": [
    {
      "$ref": "envelope.schema.json"
    }
  ],
  "properties": {
    "eventType": {
      "const": "OpportunityClosed"
    },
    "payload": {
      "$ref": "#/definitions/OpportunityClosedPayload"
    }
  },
  "definitions": {
    "OpportunityClosedPayload": {
      "type": "object",
      "required": [
        "opportunityId",
        "tenantId",
        "corporateId",
        "tripId",
        "travellerId",
        "opportunityType",
        "closureReason",
        "finalScore",
        "closedAt"
      ],
      "properties": {
        "opportunityId": {
          "type": "string",
          "format": "uuid"
        },
        "tenantId": {
          "type": "string",
          "format": "uuid"
        },
        "corporateId": {
          "type": "string",
          "format": "uuid"
        },
        "tripId": {
          "type": "string",
          "format": "uuid"
        },
        "travellerId": {
          "type": "string",
          "format": "uuid"
        },
        "opportunityType": {
          "type": "string",
          "enum": [
            "missing_hotel",
            "partial_coverage",
            "out_of_policy",
            "direct_booked",
            "preferred_supplier",
            "duty_of_care_gap",
            "orphan_hotel_review"
          ]
        },
        "closureReason": {
          "type": "string",
          "enum": [
            "hotel_added",
            "coverage_complete",
            "fulfilled",
            "resolved_without_conversion",
            "trip_cancelled",
            "expired",
            "manual_closure"
          ]
        },
        "finalScore": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "closedAt": {
          "type": "string",
          "format": "date-time"
        },
        "convertedBookingId": {
          "type": ["string", "null"],
          "format": "uuid"
        },
        "revenue": {
          "type": ["number", "null"],
          "minimum": 0
        },
        "durationDays": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "reopenCount": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "actorId": {
          "type": ["string", "null"],
          "format": "uuid"
        },
        "actorType": {
          "type": ["string", "null"],
          "enum": ["system", "tmc_user", "tmc_admin", "corporate_admin", "platform_admin", null]
        },
        "notes": {
          "type": ["string", "null"],
          "maxLength": 1000
        },
        "triggeringEventId": {
          "type": ["string", "null"],
          "format": "uuid"
        },
        "triggeringEventType": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": false
    }
  }
}
